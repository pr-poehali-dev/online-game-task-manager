{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without token forbidden",
      "method": "GET",
      "path": "/",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without token forbidden",
      "method": "POST",
      "path": "/",
      "body": {"action": "set_role", "user_id": 1, "role": "admin"},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST impersonate without token forbidden",
      "method": "POST",
      "path": "/",
      "body": {"action": "impersonate", "user_id": 1},
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
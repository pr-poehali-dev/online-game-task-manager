# ==== Секреты приложения ====
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОМУ не показывайте .env и не коммитьте его в git.

# Подключение к PostgreSQL (host обычно localhost, если БД на этом же сервере)
DATABASE_URL=postgresql://era_user:ВАШ_ПАРОЛЬ@localhost:5432/era_db

# Имя схемы в базе. Если не знаете — оставьте public
MAIN_DB_SCHEMA=public

# Доступ к S3-хранилищу (MinIO или внешний Object Storage)
AWS_ACCESS_KEY_ID=ВАШ_КЛЮЧ
AWS_SECRET_ACCESS_KEY=ВАШ_СЕКРЕТ

# Telegram-бот (создаётся у @BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-ВАШ_ТОКЕН
TELEGRAM_BOT_USERNAME=era_task_bot

# Адрес вашего сайта (для ссылок в уведомлениях). Без слэша в конце
APP_URL=https://ваш-домен.ру

# Путь к папке backend (обычно менять не нужно)
BACKEND_DIR=/var/www/era/backend

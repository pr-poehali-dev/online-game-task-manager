# Скопируйте в .env и заполните. Не коммитьте .env!

# --- PostgreSQL (контейнер создаст БД с этими данными) ---
POSTGRES_USER=era_user
POSTGRES_PASSWORD=ПРИДУМАЙТЕ_ПАРОЛЬ
POSTGRES_DB=era_db

# Схема БД. Если миграции используют схему public — оставьте public.
# Если в db_migrations длинное имя схемы (t_p...) — укажите его.
MAIN_DB_SCHEMA=public

# --- MinIO (S3) — эти же значения станут ключами доступа к хранилищу ---
AWS_ACCESS_KEY_ID=era_s3_key
AWS_SECRET_ACCESS_KEY=ПРИДУМАЙТЕ_S3_ПАРОЛЬ

# Публичный адрес картинок (как их отдаёт наружу ваш Nginx, см. README)
S3_PUBLIC_URL=https://ВАШ-ДОМЕН.РУ/files

# --- Telegram-бот ---
TELEGRAM_BOT_TOKEN=123456:ABC-ВАШ_ТОКЕН
TELEGRAM_BOT_USERNAME=era_task_bot

# --- Адрес сайта ---
APP_URL=https://ВАШ-ДОМЕН.РУ

++++    calc_hash = hmac.new(secret_key, check_string.encode(), hashlib.sha256).hexdigest()
++++    if not hmac.compare_digest(calc_hash, received_hash):
++++        return False
++++    auth_date = int(data.get('auth_date', 0))
++++    if time.time() - auth_date > 86400:
++++        return False
++++    return True

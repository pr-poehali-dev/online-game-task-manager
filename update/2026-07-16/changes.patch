+          {initialsFor(name)}
+        </div>
+      )}
+      <div className="flex-1 min-w-0">
+        <div className="flex items-center gap-2 mb-0.5">
+          <span className="text-xs font-medium">{name}</span>
+          <span className="text-xs text-muted-foreground">{fmtDate(comment.createdAt)}</span>
+          {!isReply && (
+            <button

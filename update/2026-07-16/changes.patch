++++def _public_url(key):
++++    public_url = os.environ.get('S3_PUBLIC_URL', '').rstrip('/')
++++    if public_url:
++++        return f"{public_url}/{key}"
++++    return f"https://cdn.poehali.dev/projects/{os.environ['AWS_ACCESS_KEY_ID']}/bucket/{key}"

+++          <Icon name="Download" size={13} className="text-muted-foreground shrink-0" />
+++        </a>
+++      ))}
+++    </div>
+++  );
+++}
+++
+++export default function AttachmentsField({
+++  attachments,
+++  onChange,
+++  uploadUrl,
+++  authHeaders,

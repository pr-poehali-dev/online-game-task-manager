+    app_url = (os.environ.get('APP_URL') or '').rstrip('/')
+    if not app_url:
+        return None
+    return f"{app_url}/?idea={topic_id}" if topic_id else app_url
+
+
+def _notify_reply_or_mention(cur, schema, user_id, topic_id, topic_title, kind):

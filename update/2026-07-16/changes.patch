+    icon = '↩️' if kind == 'reply' else '📣'
+    text = f"{icon} {label}:\n\n«{topic_title}»"
+    button_url = _idea_url(topic_id)
+    for tg_id in _telegram_targets(cur, schema, [user_id]):
+        _tg_send(tg_id, text, button_url)

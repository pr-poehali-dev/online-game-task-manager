+++++  { key: 'knowledge', label: 'База знаний', icon: 'BookOpen', section: 'knowledge', urlParam: 'article' },
+++++  { key: 'ideas', label: 'Идеи', icon: 'Lightbulb', section: 'ideas', urlParam: 'idea' },

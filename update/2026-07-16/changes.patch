+  open:    { label: 'Открыто',                color: '210 80% 62%', icon: 'MessageCircle' },
+  wont_do: { label: 'Решено не делать',       color: '0 65% 60%',   icon: 'XCircle' },
+  sent:    { label: 'Отправлено на реализацию', color: '152 55% 50%', icon: 'Rocket' },
